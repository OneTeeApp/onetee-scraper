# OneTee local runner credentials.
# Copy this file to "local.env" (same folder) and paste your Cloudflare API
# token below. Account ID and D1 database ID are already filled in for OneTee.
#
# The API token needs D1 edit permission. You can reuse the same token you
# added to the GitHub repo secret, or create a fresh one at:
#   Cloudflare dashboard -> My Profile -> API Tokens -> Create Token
#   -> use the "Edit D1" template (or custom: Account | D1 | Edit).
#
# This file stays on your PC only. Do not commit it or share it.

CLOUDFLARE_ACCOUNT_ID=1b380acad1c1fd73ecf14983e7bc3a4c
CLOUDFLARE_D1_DB_ID=816b0f14-b3d5-4f2b-97fb-4dc6f4e5632d
CLOUDFLARE_API_TOKEN=paste-your-d1-token-here
